<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>

  <!--
    Right-sidebar layout - mirror of the baseline. Content on the
    left, sidebar (branding + user + status + alerts + I/O + E-STOP +
    clock + version) on the right. Same widget IDs as main-window.ui
    so MainWindow.cpp does not need to know which side the sidebar
    lives on. Card-based visual system; see main-window.ui for the
    detailed comments on each section.
  -->
  <object class="GtkBox" id="root_container">
    <property name="orientation">horizontal</property>
    <property name="spacing">0</property>

    <!-- LEFT CONTENT AREA -->
    <child>
      <object class="GtkBox" id="content_area">
        <property name="orientation">vertical</property>
        <property name="hexpand">true</property>
        <property name="vexpand">true</property>

        <child>
          <object class="GtkNotebook" id="main_notebook">
            <property name="hexpand">true</property>
            <property name="vexpand">true</property>
            <property name="tab-pos">top</property>
          </object>
        </child>

        <child>
          <object class="GtkBox" id="log_panel">
            <property name="orientation">vertical</property>
            <property name="visible">false</property>
            <property name="height-request">70</property>
            <property name="css-classes">log-panel</property>

            <child>
              <object class="GtkScrolledWindow" id="log_scroll">
                <property name="vexpand">true</property>
                <property name="hexpand">true</property>
                <child>
                  <object class="GtkTextView" id="log_text_view">
                    <property name="editable">false</property>
                    <property name="cursor-visible">false</property>
                    <property name="monospace">true</property>
                    <property name="wrap-mode">word</property>
                    <property name="css-classes">log-text</property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>

    <!-- RIGHT SIDEBAR - branding + user + status + alerts + I/O + Close -->
    <child>
      <object class="GtkBox" id="sidebar">
        <property name="orientation">vertical</property>
        <property name="width-request">200</property>
        <property name="css-classes">sidebar</property>

        <!-- Brand header: logo + app title + subtitle -->
        <child>
          <object class="GtkBox" id="sidebar_header">
            <property name="orientation">horizontal</property>
            <property name="spacing">12</property>
            <property name="css-classes">sidebar-brand</property>

            <child>
              <object class="GtkBox" id="app_logo">
                <property name="css-classes">app-logo</property>
                <property name="valign">center</property>
              </object>
            </child>

            <child>
              <object class="GtkBox" id="brand_text_column">
                <property name="orientation">vertical</property>
                <property name="spacing">2</property>
                <property name="valign">center</property>
                <property name="hexpand">true</property>

                <child>
                  <object class="GtkLabel" id="app_title">
                    <property name="label" translatable="yes">Industrial HMI</property>
                    <property name="css-classes">sidebar-title</property>
                    <property name="xalign">0</property>
                  </object>
                </child>

                <child>
                  <object class="GtkLabel" id="app_subtitle">
                    <property name="label" translatable="yes">Production Monitor</property>
                    <property name="css-classes">sidebar-subtitle</property>
                    <property name="xalign">0</property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>

        <!-- USER card mount -->
        <child>
          <object class="GtkBox" id="user_container">
            <property name="orientation">vertical</property>
          </object>
        </child>

        <!-- STATUS section -->
        <child>
          <object class="GtkLabel" id="status_section_header">
            <property name="label" translatable="yes">STATUS</property>
            <property name="css-classes">sidebar-section-header</property>
            <property name="xalign">0</property>
          </object>
        </child>

        <child>
          <object class="GtkBox" id="system_status_container">
            <property name="orientation">vertical</property>
          </object>
        </child>

        <!-- ALERTS panel mount -->
        <child>
          <object class="GtkBox" id="alerts_container">
            <property name="orientation">vertical</property>
            <property name="vexpand">true</property>
          </object>
        </child>

        <!-- I/O section -->
        <child>
          <object class="GtkLabel" id="io_section_header">
            <property name="label" translatable="yes">I/O</property>
            <property name="css-classes">sidebar-section-header</property>
            <property name="xalign">0</property>
          </object>
        </child>

        <child>
          <object class="GtkBox" id="backend_health_container">
            <property name="orientation">vertical</property>
            <property name="margin-start">12</property>
            <property name="margin-end">12</property>
            <property name="margin-bottom">8</property>
          </object>
        </child>

        <!-- Emergency Stop -->
        <child>
          <object class="GtkButton" id="estop_button">
            <property name="label" translatable="yes">E-STOP</property>
            <property name="margin-start">20</property>
            <property name="margin-end">20</property>
            <property name="margin-bottom">8</property>
            <property name="css-classes">sidebar-estop</property>
          </object>
        </child>

        <!-- Close Application -->
        <child>
          <object class="GtkButton" id="close_app_button">
            <property name="label" translatable="yes">Close Application</property>
            <property name="margin-start">20</property>
            <property name="margin-end">20</property>
            <property name="margin-bottom">12</property>
            <property name="css-classes">sidebar-close-app</property>
          </object>
        </child>

        <!-- Live clock mount point -->
        <child>
          <object class="GtkBox" id="clock_container">
            <property name="orientation">vertical</property>
            <property name="margin-bottom">12</property>
          </object>
        </child>

        <!-- Footer - version info -->
        <child>
          <object class="GtkBox" id="sidebar_footer">
            <property name="orientation">vertical</property>
            <property name="spacing">4</property>
            <property name="margin-bottom">20</property>
            <property name="margin-start">20</property>
            <property name="margin-end">20</property>

            <child>
              <object class="GtkLabel" id="version_label">
                <property name="label" translatable="yes">Version 1.2.0</property>
                <property name="css-classes">sidebar-version</property>
                <property name="xalign">0</property>
              </object>
            </child>

            <child>
              <object class="GtkLabel" id="author_label">
                <property name="label" translatable="yes">Portfolio Demo</property>
                <property name="css-classes">sidebar-author</property>
                <property name="xalign">0</property>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
