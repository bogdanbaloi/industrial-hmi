<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>

  <!--
    Main window layout.

    Sidebar:  branding + Close Application + version footer.
    Content:  GtkNotebook with three tabs — Dashboard, Products, Settings.
              Log panel docked below the notebook, hidden by default and
              toggled from the Settings page.
  -->
  <object class="GtkBox" id="root_container">
    <property name="orientation">horizontal</property>
    <property name="spacing">0</property>

    <!-- LEFT SIDEBAR - branding + Close -->
    <child>
      <object class="GtkBox" id="sidebar">
        <property name="orientation">vertical</property>
        <property name="width-request">200</property>
        <property name="css-classes">sidebar</property>

        <!-- Logo / branding -->
        <child>
          <object class="GtkBox" id="sidebar_header">
            <property name="orientation">vertical</property>
            <property name="spacing">8</property>
            <property name="margin-top">24</property>
            <property name="margin-bottom">24</property>
            <property name="margin-start">20</property>
            <property name="margin-end">20</property>
            <property name="css-classes">sidebar-header</property>

            <child>
              <object class="GtkLabel" id="app_title">
                <property name="label" translatable="yes">[BB] Industrial HMI</property>
                <property name="css-classes">sidebar-title</property>
                <property name="xalign">0</property>
              </object>
            </child>

            <child>
              <object class="GtkLabel" id="app_subtitle">
                <property name="label" translatable="yes">MVP Architecture</property>
                <property name="css-classes">sidebar-subtitle</property>
                <property name="xalign">0</property>
              </object>
            </child>
          </object>
        </child>

        <child>
          <object class="GtkSeparator">
            <property name="orientation">horizontal</property>
            <property name="margin-start">12</property>
            <property name="margin-end">12</property>
          </object>
        </child>

        <!-- AlertsPanel injection point. MainWindow appends the
             widget here at startup; the GtkBox is vexpand so it fills
             the remaining sidebar height and pushes Close+footer down. -->
        <child>
          <object class="GtkBox" id="alerts_container">
            <property name="orientation">vertical</property>
            <property name="vexpand">true</property>
          </object>
        </child>

        <!-- Close Application button -->
        <child>
          <object class="GtkButton" id="close_app_button">
            <property name="label" translatable="yes">Close Application</property>
            <property name="margin-start">20</property>
            <property name="margin-end">20</property>
            <property name="margin-bottom">12</property>
            <property name="css-classes">sidebar-close-app</property>
          </object>
        </child>

        <!-- Footer - version info -->
        <child>
          <object class="GtkBox" id="sidebar_footer">
            <property name="orientation">vertical</property>
            <property name="spacing">4</property>
            <property name="margin-bottom">20</property>
            <property name="margin-start">20</property>
            <property name="margin-end">20</property>

            <child>
              <object class="GtkLabel" id="version_label">
                <property name="label" translatable="yes">Version 1.0.0</property>
                <property name="css-classes">sidebar-version</property>
                <property name="xalign">0</property>
              </object>
            </child>

            <child>
              <object class="GtkLabel" id="author_label">
                <property name="label" translatable="yes">Portfolio Demo</property>
                <property name="css-classes">sidebar-author</property>
                <property name="xalign">0</property>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>

    <!-- RIGHT CONTENT AREA -->
    <child>
      <object class="GtkBox" id="content_area">
        <property name="orientation">vertical</property>
        <property name="hexpand">true</property>
        <property name="vexpand">true</property>

        <!--
          Notebook is intentionally empty here. MainWindow::registerPage()
          appends each concrete Page as a tab programmatically so adding or
          rebuilding pages (e.g. for live language reload) doesn't require
          touching this .ui file.
        -->
        <child>
          <object class="GtkNotebook" id="main_notebook">
            <property name="hexpand">true</property>
            <property name="vexpand">true</property>
            <property name="tab-pos">top</property>
          </object>
        </child>

        <!-- Log Panel (hidden by default, toggled from Settings) -->
        <child>
          <object class="GtkBox" id="log_panel">
            <property name="orientation">vertical</property>
            <property name="visible">false</property>
            <property name="height-request">150</property>
            <property name="css-classes">log-panel</property>

            <child>
              <object class="GtkScrolledWindow" id="log_scroll">
                <property name="vexpand">true</property>
                <property name="hexpand">true</property>
                <child>
                  <object class="GtkTextView" id="log_text_view">
                    <property name="editable">false</property>
                    <property name="cursor-visible">false</property>
                    <property name="monospace">true</property>
                    <property name="wrap-mode">word</property>
                    <property name="css-classes">log-text</property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>

      </object>
    </child>
  </object>
</interface>
