<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>

  <object class="GtkBox" id="inspection_root">
    <property name="orientation">vertical</property>
    <property name="spacing">20</property>
    <property name="margin-start">60</property>
    <property name="margin-end">60</property>
    <property name="margin-top">40</property>
    <property name="margin-bottom">40</property>

    <!-- ============================================================== -->
    <!-- TOOLBAR                                                         -->
    <!-- ============================================================== -->
    <child>
      <object class="GtkBox" id="toolbar">
        <property name="orientation">horizontal</property>
        <property name="spacing">15</property>
        <property name="margin-bottom">20</property>

        <child>
          <object class="GtkLabel">
            <property name="label" translatable="yes">Edge AI Inspection</property>
            <property name="css-classes">page-title</property>
            <property name="hexpand">true</property>
            <property name="xalign">0</property>
          </object>
        </child>

        <child>
          <object class="GtkButton" id="btn_choose_image">
            <property name="label" translatable="yes">Choose image...</property>
            <property name="css-classes">toolbar-button</property>
          </object>
        </child>
      </object>
    </child>

    <!-- ============================================================== -->
    <!-- STATUS LINE                                                     -->
    <!-- ============================================================== -->
    <child>
      <object class="GtkLabel" id="lbl_status">
        <property name="label" translatable="yes">Pick an image to classify.</property>
        <property name="css-classes">inspection-status</property>
        <property name="xalign">0</property>
        <property name="margin-bottom">10</property>
      </object>
    </child>

    <!-- ============================================================== -->
    <!-- BODY: preview (left) + results (right)                          -->
    <!-- ============================================================== -->
    <child>
      <object class="GtkBox" id="body">
        <property name="orientation">horizontal</property>
        <property name="spacing">20</property>
        <property name="vexpand">true</property>

        <!-- ............................................................ -->
        <!-- PREVIEW                                                        -->
        <!-- ............................................................ -->
        <child>
          <object class="GtkFrame" id="preview_frame">
            <property name="label" translatable="yes">Preview</property>
            <property name="css-classes">inspection-card</property>
            <property name="hexpand">true</property>
            <property name="vexpand">true</property>

            <child>
              <object class="GtkBox" id="preview_container">
                <property name="orientation">vertical</property>
                <property name="margin-start">12</property>
                <property name="margin-end">12</property>
                <property name="margin-top">12</property>
                <property name="margin-bottom">12</property>

                <child>
                  <object class="GtkPicture" id="preview_image">
                    <property name="can-shrink">true</property>
                    <property name="hexpand">true</property>
                    <property name="vexpand">true</property>
                    <property name="height-request">320</property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>

        <!-- ............................................................ -->
        <!-- RESULTS                                                       -->
        <!-- ............................................................ -->
        <child>
          <object class="GtkFrame" id="results_frame">
            <property name="label" translatable="yes">Top results</property>
            <property name="css-classes">inspection-card</property>
            <property name="width-request">340</property>
            <property name="vexpand">true</property>

            <child>
              <object class="GtkBox" id="results_box">
                <property name="orientation">vertical</property>
                <property name="spacing">12</property>
                <property name="margin-start">16</property>
                <property name="margin-end">16</property>
                <property name="margin-top">16</property>
                <property name="margin-bottom">16</property>
                <property name="valign">start</property>

                <!-- Empty-state placeholder; replaced at run time. -->
                <child>
                  <object class="GtkLabel" id="lbl_results_hint">
                    <property name="label" translatable="yes">Choose an image to run inspection.</property>
                    <property name="css-classes">inspection-hint</property>
                    <property name="halign">center</property>
                    <property name="valign">center</property>
                    <property name="hexpand">true</property>
                    <property name="vexpand">true</property>
                    <property name="wrap">true</property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
