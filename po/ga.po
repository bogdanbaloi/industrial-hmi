msgid ""
"Could not load configuration from {}. Re-install the application or restore "
"the config file."
msgstr "Níorbh fhéidir an chumraíocht a lódáil ó {}. Athshuiteáil an feidhmchlár nó cuir an comhad cumraíochta ar ais."

msgid ""
"SQLite initialisation failed. Check logs for details and verify disk space / "
"permissions for the database path."
msgstr "Theip ar thúsú SQLite. Seiceáil na lomaí agus fíoraigh an spás diosca / na ceadanna don chosán bunachair shonraí."

